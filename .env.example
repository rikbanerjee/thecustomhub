# Firebase Configuration
# Copy this file to .env and fill in your actual Firebase credentials
# Get these values from: https://console.firebase.google.com > Project Settings > General > Your apps > Web app

# Firebase API Key
VITE_FIREBASE_API_KEY=your_api_key_here

# Firebase Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=thecustomhub.firebaseapp.com

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=thecustomhub

# Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=thecustomhub.appspot.com

# Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id

# Firebase App ID
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Measurement ID (optional - for Google Analytics)
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Email sending (Contact form, /custom-orders, homepage quick-lead form, newsletter
# signup) is server-side via the `sendInquiryEmail` Cloud Function using Resend —
# no client-side email keys needed. See functions/index.js and RESEND_API_KEY below
# (set via `firebase functions:secrets:set RESEND_API_KEY`, not in this file).

# Stripe Configuration
# Get your publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# Stripe secret key is set via Firebase Functions config (NOT here — it's backend-only):
#   firebase functions:config:set stripe.secret_key="sk_live_..."

# Note: All VITE_ prefixed variables are exposed to the client-side code
# Do not store sensitive information here that shouldn't be public
