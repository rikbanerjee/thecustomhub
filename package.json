{
  "name": "thecustomhub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode production && npx vite-bundle-visualizer",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "npm run predeploy && firebase deploy --only hosting",
    "deploy:all": "npm run predeploy && firebase deploy",
    "firebase:init": "firebase init hosting",
    "firebase:login": "firebase login",
    "firebase:serve": "firebase serve --only hosting",
    "clean": "rm -rf dist node_modules/.vite",
    "amazon:generate": "node src/amazon/generator.js",
    "amazon:test": "node src/amazon/test.js",
    "amazon:test-defaults": "node src/amazon/test-defaults.js",
    "walmart:generate": "node scripts/inject_walmart_feed.js",
    "etsy:match": "node scripts/add_etsy_links.js",
    "etsy:apply": "node scripts/add_etsy_links.js --apply",
    "raos:sync-functions": "node scripts/sync-raos-functions.js"
  },
  "dependencies": {
    "@retailagentos/engine": "file:vendor/retailagentos-engine-0.1.0.tgz",
    "@stripe/stripe-js": "^4.10.0",
    "@tailwindcss/postcss": "^4.1.17",
    "autoprefixer": "^10.4.22",
    "firebase": "^12.6.0",
    "postcss": "^8.5.6",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "uuid": "^13.0.0",
    "vite": "^7.2.2",
    "xlsx": "^0.18.5"
  }
}
